    "revelationPlace": "Meccan",
    "versesCount": 3,
    "verses": [
      { "number": 1, "arabic": "إِنَّا أَعْطَيْنَاكَ الْكَوْثَرَ", "pronunciation": "Inna a'taynakal-kawthar", "translation": "Indeed, We have granted you al-Kawthar." },
      { "number": 2, "arabic": "فَصَلِّ لِرَبِّكَ وَانْحَرْ", "pronunciation": "Fasalli li-rabbika wanhar", "translation": "So pray to your Lord and sacrifice to Him alone." },
      { "number": 3, "arabic": "إِنَّ شَانِئَكَ هُوَ الْأَبْتَرُ", "pronunciation": "Inna shani'aka huwal-abtar", "translation": "Indeed, your enemy is the one cut off." }
    ]
  },
  {
    "id": "an-nasr",
