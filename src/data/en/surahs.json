    "verses": [
      { "number": 1, "arabic": "قُلْ هُوَ اللَّهُ أَحَدٌ", "pronunciation": "Qul huwallahu ahad", "translation": "Say, He is Allah, who is One." },
      { "number": 2, "arabic": "اللَّهُ الصَّمَدُ", "pronunciation": "Allahus-samad", "translation": "Allah, the Eternal Refuge." },
      { "number": 3, "arabic": "لَمْ يَلِدْ وَلَمْ يُولَدْ", "pronunciation": "Lam yalid wa lam yoolad", "translation": "He neither begets nor is born." },
      { "number": 4, "arabic": "وَلَمْ يَكُن لَّهُ كُفُوًا أَحَدٌ", "pronunciation": "Wa lam yakul-lahu kufuwan ahad", "translation": "Nor is there to Him any equivalent." }
    ]
  },
  {
