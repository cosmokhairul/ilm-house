    "meaning": "The Daybreak",
    "revelationPlace": "Meccan",
    "versesCount": 5,
    "verses": [
      { "number": 1, "arabic": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ", "pronunciation": "Qul a'oothu bi rabbil-falaq", "translation": "Say, I seek refuge in the Lord of daybreak." },
      { "number": 2, "arabic": "مِن شَرِّ مَا خَلَقَ", "pronunciation": "Min sharri ma khalaq", "translation": "From the evil of that which He created." },
      { "number": 3, "arabic": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ", "pronunciation": "Wa min sharri ghasiqin itha waqab", "translation": "And from the evil of darkness when it settles." },
      { "number": 4, "arabic": "وَمِن شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ", "pronunciation": "Wa min sharrin-naffathati fil-'uqad", "translation": "And from the evil of the blowers in knots." },
      { "number": 5, "arabic": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ", "pronunciation": "Wa min sharri hasidin itha hasad", "translation": "And from the evil of an envier when he envies." }
    ]
  },
