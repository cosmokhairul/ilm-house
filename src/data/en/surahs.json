    "revelationPlace": "Medinan",
    "versesCount": 3,
    "verses": [
      { "number": 1, "arabic": "إِذَا جَاءَ نَصْرُ اللَّهِ وَالْفَتْحُ", "pronunciation": "Itha ja'a nasrullahi wal-fath", "translation": "When the victory of Allah has come and the conquest." },
      { "number": 2, "arabic": "وَرَأَيْتَ النَّاسَ يَدْخُلُونَ فِي دِينِ اللَّهِ أَفْوَاجًا", "pronunciation": "Wa ra'aytan-nasa yadkhuloona fee deenillahi afwaja", "translation": "And you see the people entering into the religion of Allah in multitudes." },
      { "number": 3, "arabic": "فَسَبِّحْ بِحَمْدِ رَبِّكَ وَاسْتَغْفِرْهُ إِنَّهُ كَانَ تَوَّابًا", "pronunciation": "Fasabbih bihamdi rabbika wastaghfirhu, innahu kana tawwaba", "translation": "Then exalt Him with praise of your Lord and ask forgiveness of Him; indeed, He is ever Accepting of repentance." }
    ]
  },
